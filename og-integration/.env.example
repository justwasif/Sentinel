# 0G Network Configuration
RPC_URL=https://evmrpc.0g.ai
# RPC_URL=https://evmrpc-testnet.0g.ai  # Testnet

# Authentication
API_KEY=sk-YOUR_API_KEY
PRIVATE_KEY=your_private_key_here

# 0G Storage
